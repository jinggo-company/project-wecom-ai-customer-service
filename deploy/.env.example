# Environment variables for WeCom Gateway
# Copy to .env and fill in real values

# WeCom Corporation
WECOM_CORP_ID=your_corp_id
WECOM_AGENT_ID=your_agent_id
WECOM_AGENT_SECRET=your_agent_secret

# Webhook Callback
WECOM_TOKEN=your_callback_token
WECOM_ENCODING_AES_KEY=your_encoding_aes_key

# Chat Archive (会话存档 - paid feature)
WECOM_CHATARCHIVE_SECRET=your_chatarchive_rsa_private_key

# Redis
REDIS_URL=redis://localhost:6379/0

# AI Engine
AI_ENGINE_URL=http://localhost:8000/api/agent/reply
AI_ENGINE_TIMEOUT=30

# Gateway
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
FLASK_SECRET_KEY=change-me-in-production
CALLBACK_BASE_URL=https://your-domain.com

# Idempotency
IDEMPOTENCY_WINDOW=300

# Retry
MAX_RETRIES=3
RETRY_BACKOFF_BASE=2.0
RETRY_INITIAL_DELAY=1.0

# Logging
LOG_LEVEL=INFO
LOG_DIR=logs

# Media Storage
MEDIA_STORAGE_PATH=/tmp/wecom_media
